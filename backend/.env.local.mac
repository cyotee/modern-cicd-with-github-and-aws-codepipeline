# Local development environment variables for macOS
# These are used when running the backend with SAM Local on macOS with Finch

HOTEL_NAME=Hotel Yorba
AWS_REGION=us-west-2
DYNAMODB_TABLE_NAME=Rooms-local
DYNAMODB_ENDPOINT=http://host.docker.internal:8000

# AWS credentials for local development (dummy values for DynamoDB Local)
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
